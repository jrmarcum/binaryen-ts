{
  "name": "@jrmarcum/binaryen-ts",
  "version": "0.1.0",
  "license": "MIT OR Apache-2.0",
  "exports": {
    ".": "./main.ts",
    "./ir": "./src/ir/index.ts",
    "./binary": "./src/binary/index.ts",
    "./encoder": "./src/encoder/index.ts",
    "./passes": "./src/passes/index.ts",
    "./api": "./src/api/index.ts",
    "./interop": "./src/interop/binaryen-js.ts",
    "./tools/wasm-opt": "./src/tools/wasm-opt.ts"
  },
  "tasks": {
    "test": "deno test --allow-read --allow-write --allow-run tests/",
    "check": "deno check src/**/*.ts main.ts",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "publish": "deno publish"
  },
  "publish": {
    "provenance": true,
    "include": [
      "main.ts",
      "src/**/*.ts",
      "tests/**/*.ts",
      "README.md",
      "LICENSE",
      "LICENSE-MIT",
      "LICENSE-APACHE"
    ],
    "exclude": [
      "tests/fixtures/**"
    ]
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window"]
  },
  "fmt": {
    "lineWidth": 100,
    "singleQuote": false,
    "indentWidth": 2
  },
  "lint": {
    "rules": {
      "include": ["no-unused-vars", "no-explicit-any", "explicit-function-return-type"]
    }
  }
}
